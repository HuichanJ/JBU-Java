import java.util.ArrayList;
import java.util.*;

abstract class Person{
    public int id;
    public String name;
    abstract String getRoleDescription();
    public void displayDetails(){
        System.out.println("Id: " + id + "\nName: " + name);
    }
}

class Students1 extends Person implements Comparable<Students1>{
    public int marks;
    Students1(int i,String n,int m) {
        this.id = i;
        this.name = n;
        this.marks = m;
    }
    
    public String getGrade(){
        return "";
    }
    public String getRoleDescription() {
    	return "";
    }
    public void displayDetails() {
    	System.out.println("Id: " + id + "\nName: " + name + "\nMarks: " + marks);
    }
    
    public int compareTo(Students1 stu) {
    	if (this.marks > stu.marks) {
    		return 1;
    	}
    	else if (this.marks < stu.marks) {
    		return -1;
    	}
    	else {
    		return this.name.compareTo(stu.name);
    	}
    }
}

public class Main {
	public static void main(String[] a) {
    	Students1 one = new Students1(001, "James", 88);
    	Students1 two = new Students1(002, "Mike", 91);
    	Students1 thr = new Students1(003, "Paul", 91);
    	
    	ArrayList<Students1> s = new ArrayList<Students1>();
    	s.add(one);
    	s.add(two);
    	s.add(thr);
    	
    	Collections.sort(s);
    	
    	for (int i = 0; i < 3; i++){
            s.get(i).displayDetails();
        }
    }
}
   


