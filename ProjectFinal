package application;

import javax.swing.*;
import java.awt.*;
import java.io.IOException;
import java.nio.file.*;
import java.util.List;
import java.util.Random;

public class ProjectFinal extends JFrame {

    JTextField passwordField;
    JButton generateBtn;
    JButton ratingBtn;
    JButton saveBtn;
    JButton viewSavedBtn;
    JTextArea outputArea;

    JFrame savedPasswordsFrame;
    JTextArea savedPasswordsArea;

    public String password = null;
    public int passLength;
    public int lowercaseLetters;
    public int capitalLetters;
    public int numbers;
    public int symbols;
    public int rating;

    public ProjectFinal() {
        setTitle("Password Strength Tester");
        setSize(650, 400);
        setLayout(null);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        JLabel label = new JLabel("Password");
        label.setBounds(40, 40, 100, 30);
        add(label);

        passwordField = new JTextField();
        passwordField.setBounds(140, 40, 350, 30);
        add(passwordField);

        generateBtn = new JButton("Generate");
        generateBtn.setBounds(80, 100, 120, 30);
        add(generateBtn);

        ratingBtn = new JButton("Get Rating");
        ratingBtn.setBounds(220, 100, 120, 30);
        add(ratingBtn);

        saveBtn = new JButton("Save Password");
        saveBtn.setBounds(360, 100, 130, 30);
        add(saveBtn);

        viewSavedBtn = new JButton("View Saved Passwords");
        viewSavedBtn.setBounds(500, 100, 130, 30);
        add(viewSavedBtn);

        outputArea = new JTextArea();
        outputArea.setBounds(40, 160, 550, 170);
        outputArea.setEditable(false);
        add(outputArea);

        generateBtn.addActionListener(e -> {
            password = generateNewPassword();
            passwordField.setText(password);
        });

        ratingBtn.addActionListener(e -> {
            password = passwordField.getText();

            if (password.isEmpty()) {
                outputArea.setText("Enter a password first.");
                return;
            }

            submitPassword();
            outputArea.setText(checkStrength());

            if (rating < 60) {
                outputArea.append(suggestions());
            }
        });

        saveBtn.addActionListener(e -> {
            password = passwordField.getText();

            if (password.isEmpty()) {
                outputArea.setText("Enter a password before saving.");
                return;
            }

            savePassword();
        });

        viewSavedBtn.addActionListener(e -> toggleSavedPasswordsWindow());

        setVisible(true);
    }

    public void submitPassword() {
        lowercaseLetters = 0;
        capitalLetters = 0;
        numbers = 0;
        symbols = 0;

        passLength = password.length();

        for (int i = 0; i < passLength; i++) {
            char var = password.charAt(i);

            if (Character.isLetter(var)) {
                if (Character.isUpperCase(var)) {
                    capitalLetters++;
                } else {
                    lowercaseLetters++;
                }
            } else if (Character.isDigit(var)) {
                numbers++;
            } else {
                symbols++;
            }
        }
    }

    public String checkStrength() {
        String output = "";

        rating = (lowercaseLetters + capitalLetters * 2 + numbers * 2 + symbols * 5);

        output += "Password: " + password + "\n";
        output += "Lowercase: " + lowercaseLetters + "\n";
        output += "Uppercase: " + capitalLetters + "\n";
        output += "Numbers: " + numbers + "\n";
        output += "Symbols: " + symbols + "\n";
        output += "Rating: " + rating + "\n";

        if (rating <= 10) {
            output += "Extremely weak password\n";
        } else if (rating <= 25) {
            output += "Weak password\n";
        } else if (rating <= 40) {
            output += "Average password\n";
        } else if (rating <= 60) {
            output += "Strong password\n";
        } else {
            output += "Very strong password\n";
        }

        return output;
    }

    public String suggestions() {
        String s = "\nSuggestions:\n";

        if (passLength < 12)
            s += "- Use at least 12 characters\n";

        if (lowercaseLetters == 0)
            s += "- Add lowercase letters\n";

        if (capitalLetters == 0)
            s += "- Add uppercase letters\n";

        if (numbers == 0)
            s += "- Add numbers\n";

        if (symbols == 0)
            s += "- Add symbols\n";

        return s;
    }

    public String generateNewPassword() {
        Random r = new Random();
        String l = "abcdefghijklmnopqrstuvwxyz";
        String u = l.toUpperCase();
        String s = "!@#$%^&*()-_=+<>?";
        String password = "";

        boolean lo, up, sym, n;

        while (true) {
            password = "";
            lo = false;
            up = false;
            sym = false;
            n = false;

            int length = r.nextInt(12, 21);

            for (int i = 0; i < length; i++) {
                int num = r.nextInt(4);

                if (num == 0) {
                    password += l.charAt(r.nextInt(l.length()));
                    lo = true;
                } else if (num == 1) {
                    password += u.charAt(r.nextInt(u.length()));
                    up = true;
                } else if (num == 2) {
                    password += s.charAt(r.nextInt(s.length()));
                    sym = true;
                } else {
                    password += r.nextInt(10);
                    n = true;
                }
            }

            if (lo && up && sym && n) {
                return password;
            }
        }
    }

    public void savePassword() {
        try {
            Files.writeString(
                    Path.of("ProjectFinalData.txt"),
                    password + "\n",
                    StandardOpenOption.CREATE,
                    StandardOpenOption.APPEND
            );

            outputArea.setText("Password saved successfully.");

        } catch (IOException e) {
            outputArea.setText("Error saving password.");
            e.printStackTrace();
        }
    }

    public void toggleSavedPasswordsWindow() {
        if (savedPasswordsFrame != null && savedPasswordsFrame.isVisible()) {
            savedPasswordsFrame.dispose();
            savedPasswordsFrame = null;
            return;
        }

        savedPasswordsFrame = new JFrame("Saved Passwords");
        savedPasswordsFrame.setSize(400, 300);

        savedPasswordsArea = new JTextArea();
        savedPasswordsArea.setEditable(false);

        try {
            List<String> passwords = Files.readAllLines(Path.of("ProjectFinalData.txt"));

            for (String pass : passwords) {
                savedPasswordsArea.append(pass + "\n");
            }

        } catch (IOException e) {
            savedPasswordsArea.setText("No saved passwords found.");
        }

        savedPasswordsFrame.add(new JScrollPane(savedPasswordsArea));
        savedPasswordsFrame.setVisible(true);
    }

    public static void main(String[] args) {
        new ProjectFinal();
    }
}
